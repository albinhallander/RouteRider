# Routing provider
# ----------------------------------------------------------------------
# By default the app uses OSRM's public demo server (no key, free-flow
# durations, car profile — fine for a prototype).
#
# Set VITE_MAPBOX_TOKEN to upgrade to traffic-aware, Google-parity
# durations (100k req/month free). Signup: https://account.mapbox.com/access-tokens/
# VITE_MAPBOX_TOKEN=pk.your_token_here

# Sustainability enrichment (data_collection/sustainability_enrich.py)
# ----------------------------------------------------------------------
# Used by the offline Python script that classifies each carrier/shipper
# on sustainability signals (website + news). Not read by the frontend.
# OPENAI_API_KEY=sk-your_key_here
# OPENAI_SUSTAIN_MODEL=gpt-4o-mini   # optional override
